# Multi-Environment Deployment — Staging Instance
#
# Only handles staging environments. Pair with production in a separate deployment.

allowed_environments:
  - staging

respond_to_unscoped: false

storage:
  dsn: "secretsmanager:schemabot-staging/storage-dsn#dsn"

github:
  app-id: "secretsmanager:schemabot-staging/github-app#app-id"
  private-key: "secretsmanager:schemabot-staging/github-app#private-key"
  webhook-secret: "secretsmanager:schemabot-staging/github-app#webhook-secret"

databases:
  testapp:
    type: mysql
    environments:
      staging:
        dsn: "secretsmanager:schemabot-staging/testapp-staging#dsn"
  payments:
    type: mysql
    environments:
      staging:
        dsn: "secretsmanager:schemabot-staging/payments-staging#dsn"
  orders:
    type: mysql
    environments:
      staging:
        dsn: "secretsmanager:schemabot-staging/orders-staging#dsn"
  inventory:
    type: mysql
    environments:
      staging:
        dsn: "secretsmanager:schemabot-staging/inventory-staging#dsn"

  # Vitess (PlanetScale) — optional, requires bootstrap-planetscale.sh setup.
  # Set organization to your PlanetScale org after running the bootstrap script.
  # Safe to leave as-is if not using PlanetScale — credentials are resolved lazily.
  commerce:
    type: vitess
    environments:
      staging:
        organization: "PLACEHOLDER"
        token_secret_ref: "secretsmanager:schemabot-staging/planetscale-token#token"
        dsn: "secretsmanager:schemabot-staging/planetscale-vtgate#dsn"
